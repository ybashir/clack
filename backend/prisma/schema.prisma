generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum ChannelRole {
  OWNER
  MODERATOR
  MEMBER
}

model User {
  id            Int       @id @default(autoincrement())
  email         String    @unique @db.VarChar(255)
  googleId      String?   @unique @db.VarChar(255)
  password      String?   @db.VarChar(255)
  name          String    @db.VarChar(100)
  avatar        String?   @db.VarChar(500)
  status        String?   @default("online") @db.VarChar(20)
  bio           String?   @db.VarChar(500)
  role          Role      @default(MEMBER)
  deactivatedAt DateTime?
  tokenVersion  Int       @default(0)
  lastSeen      DateTime  @default(now())
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt

  messages           Message[]
  channels           ChannelMember[]
  reactions          Reaction[]
  dmReactions        DMReaction[]
  files              File[]
  sentDMs            DirectMessage[] @relation("SentMessages")
  receivedDMs        DirectMessage[] @relation("ReceivedMessages")
  channelReads       ChannelRead[]
  bookmarks          Bookmark[]
  scheduledMessages  ScheduledMessage[]
  inviteLinks        InviteLink[]
  auditLogs          AuditLog[]
}

model InviteLink {
  id        Int       @id @default(autoincrement())
  code      String    @unique @db.VarChar(64)
  createdBy Int
  role      Role      @default(MEMBER)
  maxUses   Int?
  useCount  Int       @default(0)
  expiresAt DateTime?
  createdAt DateTime  @default(now())
  creator   User      @relation(fields: [createdBy], references: [id])
}

model Channel {
  id         Int       @id @default(autoincrement())
  name       String    @unique @db.VarChar(80)
  isPrivate  Boolean   @default(false)
  createdBy  Int?
  archivedAt DateTime?
  createdAt  DateTime  @default(now())

  messages           Message[]
  members            ChannelMember[]
  reads              ChannelRead[]
  scheduledMessages  ScheduledMessage[]
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String   @db.VarChar(100)
  actorId    Int
  targetType String   @db.VarChar(50)
  targetId   Int?
  targetName String?  @db.VarChar(200)
  details    String?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([actorId])
}

model ChannelMember {
  userId    Int
  channelId Int
  role      ChannelRole @default(MEMBER)
  joinedAt  DateTime    @default(now())

  user      User     @relation(fields: [userId], references: [id])
  channel   Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([userId, channelId])
}

model Message {
  id        Int       @id @default(autoincrement())
  content   String
  userId    Int
  channelId Int
  threadId  Int?
  isPinned  Boolean   @default(false)
  pinnedBy  Int?
  pinnedAt  DateTime?
  editedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @default(now()) @updatedAt
  deletedAt DateTime?

  user         User          @relation(fields: [userId], references: [id])
  channel      Channel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  reactions    Reaction[]
  files        File[]
  parent       Message?      @relation("MessageThread", fields: [threadId], references: [id])
  replies      Message[]     @relation("MessageThread")
  bookmarks    Bookmark[]
  channelReads ChannelRead[] @relation("ChannelReadMessage")

  @@index([channelId, createdAt])
  @@index([threadId])
}

model Reaction {
  id        Int      @id @default(autoincrement())
  emoji     String   @db.VarChar(50)
  userId    Int
  messageId Int
  createdAt DateTime @default(now())

  user      User    @relation(fields: [userId], references: [id])
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId, emoji])
  @@index([messageId])
}

model File {
  id           Int      @id @default(autoincrement())
  filename     String   @db.VarChar(255)
  originalName String   @db.VarChar(255)
  mimetype     String   @db.VarChar(127)
  size         Int
  url          String
  gcsPath      String?
  userId       Int
  messageId    Int?
  dmId         Int?
  createdAt    DateTime @default(now())

  user      User            @relation(fields: [userId], references: [id])
  message   Message?        @relation(fields: [messageId], references: [id], onDelete: SetNull)
  dm        DirectMessage?  @relation(fields: [dmId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([messageId])
  @@index([dmId])
}

model DirectMessage {
  id         Int       @id @default(autoincrement())
  content    String
  fromUserId Int
  toUserId   Int
  threadId   Int?
  isPinned   Boolean   @default(false)
  pinnedBy   Int?
  pinnedAt   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt
  editedAt   DateTime?
  deletedAt  DateTime?
  readAt     DateTime?

  fromUser   User             @relation("SentMessages", fields: [fromUserId], references: [id])
  toUser     User             @relation("ReceivedMessages", fields: [toUserId], references: [id])
  parent     DirectMessage?   @relation("DMThread", fields: [threadId], references: [id])
  replies    DirectMessage[]  @relation("DMThread")
  reactions  DMReaction[]
  files      File[]

  @@index([fromUserId, toUserId])
  @@index([toUserId, fromUserId])
  @@index([threadId])
}

model DMReaction {
  id        Int      @id @default(autoincrement())
  emoji     String   @db.VarChar(50)
  userId    Int
  dmId      Int
  createdAt DateTime @default(now())

  user User           @relation(fields: [userId], references: [id])
  dm   DirectMessage   @relation(fields: [dmId], references: [id], onDelete: Cascade)

  @@unique([userId, dmId, emoji])
  @@index([dmId])
}

model Bookmark {
  id        Int      @id @default(autoincrement())
  userId    Int
  messageId Int
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
  @@index([userId])
}

model ChannelRead {
  id                Int      @id @default(autoincrement())
  userId            Int
  channelId         Int
  lastReadMessageId Int?
  updatedAt         DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
  channel         Channel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  lastReadMessage Message? @relation("ChannelReadMessage", fields: [lastReadMessageId], references: [id], onDelete: SetNull)

  @@unique([userId, channelId])
}

model ScheduledMessage {
  id          Int      @id @default(autoincrement())
  content     String
  channelId   Int
  userId      Int
  scheduledAt DateTime
  createdAt   DateTime @default(now())
  sent        Boolean  @default(false)

  user    User    @relation(fields: [userId], references: [id])
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([scheduledAt, sent])
  @@index([userId])
}
