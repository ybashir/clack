# Database connection string
# For production, append ?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/slackclone"

# JWT secret - REQUIRED in production
# Generate with: openssl rand -hex 32
JWT_SECRET=change-me-generate-with-openssl-rand-hex-32

# Server port
PORT=3000

# Environment: development | production | test
NODE_ENV=development

# CORS origin - defaults to http://localhost:5173 in development
# Set explicitly for production (e.g., https://your-domain.com)
# CORS_ORIGIN=

# Google Cloud Storage bucket name (optional - uses local storage if not set)
# GCS_BUCKET_NAME=
